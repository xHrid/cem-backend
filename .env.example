# Copy to .env and edit. docker-compose reads this automatically.
MAX_UPLOAD_MB=2048
# CORS: which web origins may call this API from a browser. "*" = any.
# Set to your static-site URL in production, e.g. https://cem-toolkit.onrender.com
ALLOWED_ORIGINS=*

# ---- Airflow dispatch (optional) ----
# Blank = /analyze runs the pipeline locally (blocking, no polling needed).
# Set AIRFLOW_BASE_URL to enable: /analyze triggers the DAG and returns a
# job_id the client polls via GET /api/v1/jobs/<job_id>. Use the internal docker
# hostname (same network), e.g. http://corestac-stacd-airflow:8080
AIRFLOW_BASE_URL=
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DAG_ID=cem_pipeline
AIRFLOW_TIMEOUT=10
# BirdNET parallel workers. Each loads its own TensorFlow model (~hundreds of
# MB). If BirdNET crashes with "BrokenProcessPool", lower to 1 and/or raise
# Docker Desktop's memory limit. Default 2.
BIRDNET_MAX_WORKERS=2

# ---- Shared host data directory (item 7) ----
# The common deployment directory on the host, bind-mounted to /data in the
# container. Data lives OUTSIDE the container; the file-browser service reads
# this same dir. Use an absolute path on the lab node, e.g. /srv/cem/data .
HOST_DATA_DIR=./data

# ---- Versioning (item 12) ----
# Compute API version stamped into outputs + STAC items. Bump on API changes.
API_VERSION=1.1.0

# ---- STAC provenance (item 9) ----
# A STAC 1.0 Item sidecar (<file>.stac.json) is written next to every output.
STAC_ENABLED=true
STAC_COLLECTION=cem-bioacoustics
# Optional: if set, STAC asset hrefs become absolute under this base URL
# (e.g. the file-browser/raw-data origin). Blank = relative hrefs.
STAC_ASSET_BASE_URL=

# ---- File-browser deep link (item 11) ----
# Base URL of the shared-data file-browser service (another team). After a job
# the API returns "<FILE_BROWSER_BASE_URL>/jobs/<job_id>" so the webapp can link
# the user to that job's output dir. Blank = no link returned.
FILE_BROWSER_BASE_URL=
# Override the link scheme if the file-browser team uses a different one.
# {base} and {job_rel} are substituted; job_rel = "jobs/<job_id>".
FILE_BROWSER_PATH_TEMPLATE={base}/{job_rel}

# ---- Output retention (item 15) ----
# The cluster is compute, not long-term storage. Job dirs older than
# RETENTION_HOURS are swept every RETENTION_SWEEP_MINUTES. 0 disables.
RETENTION_HOURS=168
RETENTION_SWEEP_MINUTES=60
