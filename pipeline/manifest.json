[
  {
    "id": "birdnet",
    "name": "BirdNET Species Detection",
    "script_file": "birdnet_predictions.py",
    "version": "1.0.0",
    "description": "Run BirdNET on raw audio: discover + filter WAV files, append detections to the shared aggregate CSV, then write a filtered output CSV for the requested spots/date range.",
    "inputs": [
      {
        "type": "spot_date_range",
        "label": "Select spots and date range",
        "valid_extensions": [".wav"]
      }
    ],
    "parameters": [
      {
        "id": "snr_db",
        "label": "SNR for noise removal (dB)",
        "type": "text",
        "default": "18"
      },
      {
        "id": "min_confidence",
        "label": "Minimum detection confidence (0-1)",
        "type": "text",
        "default": "0.25"
      }
    ],
    "depends_on": [],
    "outputs": { "master_csv": "birdnet_results.csv" },
    "aggregate_file": "birdnet_results.csv",
    "assets": ["config.py", "file_metadata.py", "static_noise.wav", "rain_noise.wav"]
  },
