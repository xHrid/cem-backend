# ---- Secrets: NEVER commit ----
.env
*.env
!.env.example

# ---- Runtime job data (uploads + results, ~GBs) ----
# Ignore the CONTENTS, not the dir itself, so .gitkeep can be re-included
# (git won't look inside a fully-ignored directory).
data/*
!data/.gitkeep

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
server/.venv/

# ---- Build / packaging ----
*.zip
*.log
build/
dist/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
